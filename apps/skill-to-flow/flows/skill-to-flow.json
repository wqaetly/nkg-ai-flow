        "maxOutputChars": 40000,
        "maxSteps": 30,
        "systemPrompt": "You are a terse build agent. Use tools to write generated files and verify the package. Stay inside working_dir.",
        "timeoutMs": 30000,
        "workingDir": "./generated/skill-to-flow-output"
      }
    }
