{
  "id": "fan_out_flow",
  "version": "1.0.0",
  "schemaVersion": "flow.graph.v1",
  "label": "Fan-Out Flow",
  "description": "Start fans out to two parallel transforms, each into its own End.",
  "nodes": [
    {
      "id": "node_start",
      "type": "start",
      "typeVersion": "1.0.0",
      "label": "Start",
      "position": {
        "x": -100,
        "y": 200
      },
      "ports": [
        {
          "id": "out",
          "direction": "output",
          "kind": "control",
          "label": "Next"
        }
      ],
      "config": {}
    },
    {
      "id": "node_upper",
      "type": "transform",
      "typeVersion": "1.0.0",
      "label": "To Upper",
      "position": {
        "x": 340,
        "y": 80
      },
      "ports": [
        {
          "id": "in",
          "direction": "input",
          "kind": "control",
          "label": "Run"
        },
        {
          "id": "out",
          "direction": "output",
          "kind": "control",
          "label": "Next"
        },
        {
          "id": "input",
          "direction": "input",
          "kind": "data",
          "label": "Input"
        },
        {
          "id": "output",
          "direction": "output",
          "kind": "data",
          "label": "Output"
        }
      ],
      "config": {
        "expression": "input.text.toUpperCase()"
      }
    },
    {
      "id": "node_lower",
      "type": "transform",
      "typeVersion": "1.0.0",
      "label": "To Lower",
      "position": {
        "x": 340,
        "y": 320
      },
      "ports": [
        {
          "id": "in",
          "direction": "input",
          "kind": "control",
          "label": "Run"
        },
        {
          "id": "out",
          "direction": "output",
          "kind": "control",
          "label": "Next"
        },
        {
          "id": "input",
          "direction": "input",
          "kind": "data",
          "label": "Input"
        },
        {
          "id": "output",
          "direction": "output",
          "kind": "data",
          "label": "Output"
        }
      ],
      "config": {
        "expression": "input.text.toLowerCase()"
      }
    },
    {
      "id": "node_end_upper",
      "type": "end",
      "typeVersion": "1.0.0",
      "label": "End (Upper)",
      "position": {
        "x": 640,
        "y": 80
      },
      "ports": [
        {
          "id": "in",
          "direction": "input",
          "kind": "control",
          "label": "Run"
        }
      ],
      "config": {}
    },
    {
      "id": "node_end_lower",
      "type": "end",
      "typeVersion": "1.0.0",
      "label": "End (Lower)",
      "position": {
        "x": 640,
        "y": 320
      },
      "ports": [
        {
          "id": "in",
          "direction": "input",
          "kind": "control",
          "label": "Run"
        }
      ],
      "config": {}
    }
  ],
  "edges": [
    {
      "id": "edge_01",
      "from": {
        "nodeId": "node_start",
        "portId": "out"
      },
      "to": {
        "nodeId": "node_upper",
        "portId": "in"
      }
    },
    {
      "id": "edge_02",
      "from": {
        "nodeId": "node_start",
        "portId": "out"
      },
      "to": {
        "nodeId": "node_lower",
        "portId": "in"
      }
    },
    {
      "id": "edge_03",
      "from": {
        "nodeId": "node_upper",
        "portId": "out"
      },
      "to": {
        "nodeId": "node_end_upper",
        "portId": "in"
      }
    },
    {
      "id": "edge_04",
      "from": {
        "nodeId": "node_lower",
        "portId": "out"
      },
      "to": {
        "nodeId": "node_end_lower",
        "portId": "in"
      }
    }
  ]
}