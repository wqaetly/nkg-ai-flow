{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@ai-native-flow/flow-ir": ["packages/flow-ir/src/index.ts"],
      "@ai-native-flow/flow-validator": ["packages/flow-validator/src/index.ts"],
      "@ai-native-flow/flow-builder": ["packages/flow-builder/src/index.ts"],
      "@ai-native-flow/builder-runner": ["packages/builder-runner/src/index.ts"],
      "@ai-native-flow/event-bus": ["packages/event-bus/src/index.ts"],
      "@ai-native-flow/net-utils": ["packages/net-utils/src/index.ts"],
      "@ai-native-flow/variable-store": ["packages/variable-store/src/index.ts"],
      "@ai-native-flow/variable-store/browser": ["packages/variable-store/src/browser.ts"],
      "@ai-native-flow/node-sdk": ["packages/node-sdk/src/index.ts"],
      "@ai-native-flow/ai-stream": ["packages/ai-stream/src/index.ts"],
      "@ai-native-flow/sandbox": ["packages/sandbox/src/index.ts"],
      "@ai-native-flow/runtime": ["packages/runtime/src/index.ts"],
      "@ai-native-flow/runtime/browser": ["packages/runtime/src/browser.ts"],
      "@ai-native-flow/transport-http": ["packages/transport-http/src/index.ts"],
      "@ai-native-flow/transport-sdk": ["packages/transports/sdk/src/index.ts"],
      "@ai-native-flow/transport-cli": ["packages/transports/cli/src/index.ts"],
      "@ai-native-flow/transport-mcp": ["packages/transports/mcp/src/index.ts"],
      "@ai-native-flow/transport-http-runner": ["packages/transports/http-runner/src/index.ts"],
      "@ai-native-flow/workspace-manifest": ["packages/workspace-manifest/src/index.ts"],
      "@ai-native-flow/studio": ["packages/studio/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/test/**/*.ts",
    "packages/*/test/**/*.tsx",
    "packages/transports/*/src/**/*.ts",
    "packages/transports/*/src/**/*.tsx",
    "packages/transports/*/test/**/*.ts",
    "packages/transports/*/test/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "**/dist/**"]
}
